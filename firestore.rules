rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each list uses a random ID in its shared URL. Keep that URL private.
    match /lists/{listId}/items/{itemId} {
      allow read: if listId.size() >= 30 && listId.size() <= 80;
      allow create: if listId.size() >= 30
        && listId.size() <= 80
        && request.resource.data.keys().hasOnly([
          'name', 'quantity', 'category', 'bought', 'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 80
        && request.resource.data.quantity is string
        && request.resource.data.quantity.size() <= 20
        && request.resource.data.category in [
          'Groceries', 'Home', 'Personal', 'Other'
        ]
        && request.resource.data.bought is bool
        && request.resource.data.createdAt is int;
      allow update: if listId.size() >= 30
        && listId.size() <= 80
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bought'])
        && request.resource.data.bought is bool;
      allow delete: if listId.size() >= 30 && listId.size() <= 80;
    }
  }
}
